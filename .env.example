# AWS Region for Bedrock
AWS_REGION=us-east-2

# --- Option 1: STS role assumption (recommended for Lambda / SageMaker) ---
# The IAM role ARN that has bedrock:InvokeModel permission.
# The calling identity (Lambda execution role, SageMaker execution role,
# or local credentials) must have sts:AssumeRole on this ARN.
BEDROCK_ROLE_ARN=arn:aws:iam::123456789012:role/BedrockInvocationRole

# --- Option 2: Direct credentials (local development only) ---
# If set, these are used directly instead of the default AWS credential chain.
# Leave blank to fall back to ~/.aws/credentials, env vars, or instance role.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
